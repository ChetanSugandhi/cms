<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-starter-parent</artifactId>
        <version>3.4.3</version>
        <relativePath/>
    </parent>

    <groupId>com.media</groupId>
    <artifactId>digital-cms-parent</artifactId>
    <version>1.0.0</version>
    <packaging>pom</packaging>

    <name>digital-cms-parent</name>
    <description>Parent project for Digital CMS multi-module backend</description>

    <modules>
        <module>cms-service</module>
        <module>cms-api</module>
        <module>cms-app</module>
    </modules>

    <properties>
        <java.version>21</java.version>
        <camunda.version>7.21.0</camunda.version>
        <jjwt.version>0.12.6</jjwt.version>
        <minio.version>8.5.12</minio.version>
    </properties>
</project>
